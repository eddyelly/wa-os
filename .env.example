# Database (postgres 16 + pgvector, see infra/docker-compose.yml)
DATABASE_URL=postgresql://waos:waos@localhost:5432/waos_dev

# Redis (BullMQ queues + Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible media storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=waos
MINIO_SECRET_KEY=waos-secret
MINIO_BUCKET=waos-media
# Endpoint for media URLs the Evolution container fetches when sending media
# (it cannot reach the host's localhost). Optional; defaults to MINIO_ENDPOINT.
# Local Docker dev (API on host, provider in a container):
MINIO_PUBLIC_ENDPOINT=host.docker.internal:9000

# Evolution API (entry tier WhatsApp transport)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-evolution-key
EVOLUTION_WEBHOOK_SECRET=change-me-webhook-secret

# Auth (JWT access/refresh token secrets, generate long random strings)
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars

# LLM (Gemini by default, model from env)
GEMINI_API_KEY=change-me-gemini-key
LLM_MODEL_ID=gemini-2.5-flash

# Embeddings (gemini reuses GEMINI_API_KEY above; EMBEDDING_API_KEY is only
# read by the voyage/openai fallback adapter)
EMBEDDING_PROVIDER=gemini
EMBEDDING_API_KEY=change-me-embedding-key
EMBEDDING_MODEL_ID=gemini-embedding-001
EMBEDDING_DIM=1536

# AI behavior
AI_CONFIDENCE_THRESHOLD=0.7

# Reminder lead times in minutes before an appointment (24h and 2h)
REMINDER_OFFSETS_MINUTES=1440,120

# Ban-risk guardrails (entry tier)
SEND_RATE_PER_MINUTE=6
WARMUP_DAILY_CAPS=20,40,60,80,120,160,200,250,300,350,400,450,500,600

# Dashboard
NEXT_PUBLIC_APP_NAME=WaOS
NEXT_PUBLIC_API_URL=http://localhost:4000

# API server
PORT=4000
NODE_ENV=development

# Dashboard origin allowed by CORS; public base URL of this API (webhooks).
WEB_ORIGIN=http://localhost:3000
# Local Docker dev: use http://host.docker.internal:4000 so Evolution webhooks
# inside the container can reach this API on the host. On a VPS set the real
# public URL (see docs/RUNBOOK.md).
API_PUBLIC_URL=http://host.docker.internal:4000
