// WaOS data model (CLAUDE.md section 7).
// Every domain table carries organizationId and is indexed on it.
// The tenant Prisma extension (src/lib/tenant.ts) injects the filter on every
// query; never query a domain table without it.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  OWNER
  STAFF
}

enum ChannelProvider {
  evolution
  cloud_api
}

enum ChannelStatus {
  PENDING
  QR_READY
  CONNECTED
  DISCONNECTED
  BANNED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  IN
  OUT
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  LOCATION
  OTHER
}

enum AuthorType {
  CONTACT
  HUMAN_AGENT
  AI
  SYSTEM
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  BLOCKED
}

enum AppointmentStatus {
  BOOKED
  REMINDED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum AiReplyAction {
  REPLIED
  HANDED_OFF
}

enum OrderStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  PAID
  FULFILLED
  CANCELLED
}

enum NotificationType {
  NEW_ORDER
  LOW_STOCK
  HANDOFF
}

model Organization {
  id       String   @id @default(cuid())
  name     String
  vertical String   @default("local-services")
  language String   @default("sw")
  timezone String   @default("Africa/Dar_es_Salaam")
  // Reserved so pricing can arrive later as a migration. Never read for gating.
  plan     String   @default("free")
  // Enabled feature modules; gates API routes, AI tools, and dashboard nav.
  modules  String[] @default(["appointments"])
  settings Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  channels        Channel[]
  contacts        Contact[]
  conversations   Conversation[]
  messages        Message[]
  knowledgeDocs   KnowledgeDoc[]
  knowledgeChunks KnowledgeChunk[]
  appointments    Appointment[]
  aiReplyLogs     AiReplyLog[]
  products        Product[]
  productImages   ProductImage[]
  orders          Order[]
  orderItems      OrderItem[]
  notifications   Notification[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedConversations Conversation[] @relation("ConversationAssignee")

  @@index([organizationId])
}

model Channel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider        ChannelProvider @default(evolution)
  // Evolution instance name; by convention it equals the channel id.
  externalId      String?         @unique
  status          ChannelStatus   @default(PENDING)
  warmupStartedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]

  @@index([organizationId])
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // E.164, e.g. +255712345678
  phone        String
  name         String?
  language     String?
  tags         String[]  @default([])
  optedInAt    DateTime?
  customFields Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]
  appointments  Appointment[]
  orders        Order[]

  @@unique([organizationId, phone])
  @@index([organizationId])
}

model Conversation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status        ConversationStatus @default(OPEN)
  assigneeId    String?
  assignee      User?              @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  aiEnabled     Boolean            @default(true)
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    Message[]
  aiReplyLogs AiReplyLog[]
  orders      Order[]

  @@unique([channelId, contactId])
  @@index([organizationId])
  @@index([organizationId, status])
}

model Message {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction         MessageDirection
  type              MessageType      @default(TEXT)
  body              String?
  // MinIO object key for media messages
  mediaKey          String?
  authorType        AuthorType
  providerMessageId String?
  status            MessageStatus    @default(QUEUED)
  // Populated when the policy engine blocks the send (PolicyDecision reason)
  blockedReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inbound idempotency guard: re-delivered webhooks must not duplicate rows.
  @@unique([organizationId, providerMessageId])
  @@index([organizationId])
  @@index([conversationId, createdAt])
}

model KnowledgeDoc {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title    String
  mimeType String @default("text/plain")
  content  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([organizationId])
}

model KnowledgeChunk {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  docId String
  doc   KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  // Position of the chunk within its doc
  index     Int
  content   String
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([docId, index])
  @@index([organizationId])
}

model Appointment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  serviceName    String
  notes          String?
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(BOOKED)
  reminderJobIds String[]          @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, startsAt])
}

model AiReplyLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  retrievedChunkIds String[]      @default([])
  confidence        Float
  action            AiReplyAction
  latencyMs         Int
  // Names of agent tools invoked for this decision.
  toolsUsed         String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([conversationId])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name              String
  description       String?
  // Whole TZS. The platform never processes payments.
  price             Int
  // Bargaining floor; null means fixed price. NEVER exposed to the model.
  minPrice          Int?
  stockQty          Int                          @default(0)
  lowStockThreshold Int                          @default(5)
  isActive          Boolean                      @default(true)
  tags              String[]                     @default([])
  // Built from name + description + image descriptions; null until embedded.
  embedding         Unsupported("vector(1536)")?

  images     ProductImage[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model ProductImage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  mediaKey    String
  // Gemini vision writes this at upload; feeds the product embedding.
  description String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([productId])
}

model Order {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  contactId      String
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status      OrderStatus @default(PENDING_CONFIRMATION)
  totalAgreed Int
  note        String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
}

model OrderItem {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Snapshot fields survive product deletion or edits.
  productName String
  quantity    Int
  listPrice   Int
  agreedPrice Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([orderId])
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type    NotificationType
  payload Json             @default("{}")
  readAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, readAt])
}
